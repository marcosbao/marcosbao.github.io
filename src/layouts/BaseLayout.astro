---
import { site } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.title} · ${site.subtitle}`,
  description = site.description
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700;800&family=Noto+Serif+SC:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg-1: #eef3f9;
        --bg-2: #f8fafc;
        --bg-3: #edf6f4;
        --text: #0b1220;
        --sub: #526071;
        --muted: #6b7280;
        --line: rgba(255, 255, 255, 0.5);
        --shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
        --shadow-soft: 0 12px 28px rgba(15, 23, 42, 0.06);
        --font-sans: 'Noto Sans SC', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
        --font-serif: 'Noto Serif SC', 'Source Han Serif SC', 'Songti SC', 'STSong', serif;
        --content-max: 760px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--text);
        background:
          radial-gradient(circle at 12% 10%, rgba(59, 130, 246, 0.16), transparent 26%),
          radial-gradient(circle at 86% 18%, rgba(20, 184, 166, 0.12), transparent 22%),
          linear-gradient(180deg, var(--bg-1), var(--bg-2) 48%, var(--bg-3));
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      a {
        color: inherit;
      }

      .container {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
      }

      .glass {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.28));
        border: 1px solid var(--line);
        backdrop-filter: blur(22px) saturate(150%);
        -webkit-backdrop-filter: blur(22px) saturate(150%);
        box-shadow: var(--shadow), inset 0 1px 0 rgba(255, 255, 255, 0.72);
      }

      .glass-soft {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.48), rgba(255, 255, 255, 0.22));
        border: 1px solid rgba(255, 255, 255, 0.46);
        backdrop-filter: blur(18px) saturate(140%);
        -webkit-backdrop-filter: blur(18px) saturate(140%);
        box-shadow: var(--shadow-soft), inset 0 1px 0 rgba(255, 255, 255, 0.64);
      }

      .site-header {
        padding: 18px 0 10px;
      }

      .site-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 18px;
        border-radius: 999px;
      }

      .site-brand {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .site-brand strong {
        font-size: 15px;
        font-weight: 800;
      }

      .site-brand span {
        font-size: 12px;
        color: var(--sub);
      }

      .site-links {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .site-links a {
        text-decoration: none;
        padding: 10px 14px;
        border-radius: 999px;
        font-size: 14px;
      }

      .site-links a:hover {
        background: rgba(255, 255, 255, 0.42);
      }

      .page-section {
        padding: 18px 0;
      }

      .hero-card,
      .content-card,
      .post-shell {
        border-radius: 32px;
        padding: 30px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        padding: 9px 13px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.46);
        border: 1px solid rgba(255, 255, 255, 0.54);
        color: #334155;
        font-size: 13px;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        font-family: var(--font-serif);
      }

      .section-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
      }

      .section-head p,
      .muted,
      .article-lead,
      .article-meta,
      .post-list p {
        color: var(--sub);
      }

      .article-body {
        max-width: var(--content-max);
      }

      .article-body :global(p),
      .article-body :global(li),
      .article-body :global(blockquote) {
        font-family: var(--font-serif);
        font-size: 18px;
        line-height: 2;
        font-weight: 500;
        color: #243142;
      }

      .article-body :global(h2),
      .article-body :global(h3) {
        margin-top: 2.2rem;
        margin-bottom: 1rem;
        font-size: 28px;
      }

      .article-body :global(img) {
        width: 100%;
        border-radius: 24px;
        display: block;
        margin: 2rem 0;
      }

      .article-body :global(a) {
        color: #0f4da8;
      }

      .footer {
        padding: 10px 0 44px;
      }

      .footer-card {
        padding: 18px 22px;
        border-radius: 24px;
      }

      @media (max-width: 720px) {
        .container {
          width: min(100% - 20px, 1120px);
        }

        .site-nav,
        .section-head {
          flex-direction: column;
          align-items: flex-start;
        }

        .hero-card,
        .content-card,
        .post-shell {
          padding: 22px;
        }

        .article-body :global(p),
        .article-body :global(li),
        .article-body :global(blockquote) {
          font-size: 17px;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <div class="site-nav glass-soft">
          <div class="site-brand">
            <strong>{site.title}</strong>
            <span>{site.subtitle}</span>
          </div>
          <nav class="site-links">
            {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
        </div>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="container">
        <div class="footer-card glass-soft muted">
          关于 AI 乱象、技术落地、项目协作，以及那些还没来得及长成结论的碎片。
        </div>
      </div>
    </footer>
  </body>
</html>
