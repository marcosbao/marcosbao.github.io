---
interface Props {
  initialTitle?: string;
  initialValue?: string;
}

const { initialTitle = '', initialValue = '' } = Astro.props;
---

<div class="editor-shell glass-soft" data-editor-shell data-initial-title={initialTitle} data-initial-value={initialValue}>
  <div class="editor-grid">
    <section class="editor-pane">
      <input id="post-title" class="title-input" type="text" value={initialTitle} placeholder="先把标题写准" />
      <div id="milkdown-root"></div>
    </section>
    <aside class="preview-pane">
      <div class="preview-card">
        <div class="preview-eyebrow">实时预览</div>
        <h1 class="preview-title" id="preview-title">{initialTitle}</h1>
        <article class="article-body" id="preview-content"></article>
      </div>
    </aside>
  </div>
</div>

<script type="module">
  import '../scripts/milkdown-editor.ts';
</script>

<style>
  .editor-shell {
    border-radius: 32px;
    padding: 24px;
  }

  .editor-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
    gap: 18px;
    margin-top: 18px;
  }

  .field-label {
    display: block;
    margin-bottom: 10px;
    color: #3b4858;
    font-size: 13px;
    font-weight: 700;
  }

  .title-input {
    width: 100%;
    margin-bottom: 18px;
    padding: 18px 20px;
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.76);
    color: var(--text);
    font-family: var(--font-serif);
    font-size: 30px;
    line-height: 1.5;
    font-weight: 700;
    outline: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  .title-input::placeholder {
    color: #7a8694;
  }

  .editor-pane,
  .preview-card {
    min-height: 680px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.52);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  .preview-card {
    padding: 24px;
  }

  .preview-eyebrow {
    display: inline-flex;
    align-items: center;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.66);
    color: #334155;
    font-size: 12px;
    margin-bottom: 18px;
  }

  .preview-title {
    margin: 0 0 22px;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  :global(#preview-content p),
  :global(#preview-content li),
  :global(#preview-content blockquote) {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 2;
    font-weight: 500;
    color: #243142;
  }

  :global(#preview-content h2),
  :global(#preview-content h3) {
    margin-top: 2.2rem;
    margin-bottom: 1rem;
    font-family: var(--font-serif);
    font-size: 28px;
    line-height: 1.35;
    letter-spacing: -0.02em;
  }

  :global(#preview-content ul),
  :global(#preview-content ol) {
    margin: 1.2rem 0;
    padding-left: 1.6rem;
  }

  :global(#preview-content li + li) {
    margin-top: 0.45rem;
  }

  :global(#preview-content blockquote) {
    margin: 1.6rem 0;
    padding-left: 1rem;
    border-left: 3px solid rgba(15, 77, 168, 0.22);
  }

  :global(.milkdown),
  :global(.milkdown-crepe) {
    min-height: 680px;
    background: transparent;
  }

  :global(.milkdown .editor),
  :global(.milkdown-crepe .editor) {
    padding: 18px 16px 24px;
  }

  :global(#milkdown-root .milkdown .ProseMirror),
  :global(#milkdown-root .milkdown-crepe .ProseMirror) {
    min-height: 620px;
    max-width: none;
    width: 100%;
    padding: 60px 40px !important;
    outline: none;
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 2;
    color: #243142;
  }

  :global(.milkdown .ProseMirror p),
  :global(.milkdown .ProseMirror li),
  :global(.milkdown .ProseMirror blockquote),
  :global(.milkdown-crepe .ProseMirror p),
  :global(.milkdown-crepe .ProseMirror li),
  :global(.milkdown-crepe .ProseMirror blockquote) {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 2;
    font-weight: 500;
  }

  :global(.milkdown .ProseMirror h1),
  :global(.milkdown .ProseMirror h2),
  :global(.milkdown .ProseMirror h3),
  :global(.milkdown-crepe .ProseMirror h1),
  :global(.milkdown-crepe .ProseMirror h2),
  :global(.milkdown-crepe .ProseMirror h3) {
    font-family: var(--font-serif);
    line-height: 1.35;
    letter-spacing: -0.02em;
  }

  :global(.milkdown .ProseMirror h1),
  :global(.milkdown-crepe .ProseMirror h1) {
    font-size: 34px;
  }

  :global(.milkdown .ProseMirror h2),
  :global(.milkdown-crepe .ProseMirror h2) {
    font-size: 28px;
  }

  :global(.milkdown .ProseMirror h3),
  :global(.milkdown-crepe .ProseMirror h3) {
    font-size: 22px;
  }

  :global(.milkdown .ProseMirror img),
  :global(.milkdown-crepe .ProseMirror img),
  :global(.milkdown-image-block img),
  :global(.milkdown-crepe .milkdown-image-block img),
  :global(#preview-content img) {
    display: block;
    max-width: 100% !important;
    width: auto !important;
    height: auto !important;
    object-fit: contain;
    border-radius: 18px;
    margin: 1.8rem 0;
  }

  :global(.milkdown-image-block),
  :global(.milkdown-crepe .milkdown-image-block) {
    max-width: 100%;
    overflow: hidden;
  }

  @media (max-width: 1024px) {
    .editor-grid {
      grid-template-columns: 1fr;
    }

    .editor-pane,
    .preview-card,
    :global(.milkdown),
    :global(.milkdown-crepe) {
      min-height: 520px;
    }

    :global(#milkdown-root .milkdown .ProseMirror),
    :global(#milkdown-root .milkdown-crepe .ProseMirror) {
      min-height: 460px;
      max-width: none;
      padding: 40px 24px !important;
    }
  }
</style>
