---
import BaseLayout from '../layouts/BaseLayout.astro';
import MilkdownEditor from '../components/MilkdownEditor.astro';

const initialTitle = '一篇文章的起点';

const initialValue = `这里先做一个极简中文写作页。

你可以直接在左侧写 Markdown，右侧会尽量按博客正文的方式实时预览。

## 为什么先做这个

- 先验证中文输入和写作手感
- 先验证排版是不是接近最终博客
- 先不接保存、不接发布、不接后台

> 写作先顺，架构后补。

![测试图片](https://aisheishei.oss-cn-beijing.aliyuncs.com/test.png)
`;
---

<BaseLayout title="编辑器 · AiSheiShei" description="极简中文 Markdown 编辑器原型。" hideChrome={true}>
  <main class="page-section">
    <div class="container">
      <div class="section-head">
        <div>
          <h1 style="font-size:44px;">Markdown 编辑器</h1>
          <p style="margin:10px 0 0;max-width:760px;line-height:1.9;">
            第一阶段先只做写作和预览，让编辑页面尽量贴近真实博客阅读效果。
          </p>
        </div>
      </div>
      <MilkdownEditor initialTitle={initialTitle} initialValue={initialValue} />
    </div>
  </main>
</BaseLayout>
